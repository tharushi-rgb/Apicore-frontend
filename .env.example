# ─── ApiCore Frontend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values for local development.
# On Render, set these as Environment Variables in the dashboard.

# Backend API URL — set this to your deployed Apicore-backend URL on Render.
# Example: https://apicore-backend.onrender.com/api
VITE_API_URL=http://localhost:5001/api
